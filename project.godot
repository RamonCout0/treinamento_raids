; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Raido"
run/main_scene="res://Lobby/lobby.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://Manager/EventBus.gd"
AudioManager="*res://Manager/AudioManager.tscn"
RaidManager="*res://Manager/RaidManager.tscn"
GameFeel="*res://Manager/GameFeel.tscn"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1152
window/size/window_height_override=648
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="Raido"

[global_group]

player=""
boss=""

